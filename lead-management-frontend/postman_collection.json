{
  "info": {
    "name": "FitLeads API",
    "description": "Lead Management System API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/leads",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Manav Rastogi\",\n  \"phone\": \"9876543210\",\n  \"email\": \"john@gmail.com\",\n  \"source\": \"website\",\n  \"status\": \"new\",\n  \"assigned_to\": \"Trainer A\"\n}"
            }
          }
        },
        {
          "name": "Get All Leads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leads?page=1&limit=10&sort_by=created_at&order=desc",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"],
              "query": [
                { "key": "page",    "value": "1" },
                { "key": "limit",   "value": "10" },
                { "key": "sort_by", "value": "created_at" },
                { "key": "order",   "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Search Leads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leads?search=john&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"],
              "query": [
                { "key": "search", "value": "john" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Filter by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leads?status=new&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"],
              "query": [
                { "key": "status", "value": "new" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Filter by Source",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leads?source=website&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"],
              "query": [
                { "key": "source", "value": "website" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Filter by Status + Source",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/leads?status=new&source=website&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"],
              "query": [
                { "key": "status", "value": "new" },
                { "key": "source", "value": "website" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update Lead Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/leads/1/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"contacted\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Metrics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/dashboard"
          }
        }
      ]
    }
  ]
}